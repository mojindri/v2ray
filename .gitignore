# Rust build output — never commit this directory.
# It can be multiple gigabytes and is fully reproducible from source.
/target/

# Cargo lock file for libraries is conventionally not committed,
# but for binaries (which this project is) we DO commit Cargo.lock
# so that CI and production builds use identical dependency versions.
# Therefore Cargo.lock is NOT listed here.

# Editor and IDE files — not part of the project.
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Environment files — may contain secrets, never commit.
.env
.env.local

# GeoIP/GeoSite data files — downloaded separately, not stored in git.
# Run `make update-geoip` to download them.
*.dat

# Fuzz corpus and artifacts — too large for git, stored separately.
fuzz/corpus/
fuzz/artifacts/

# Claude Code agent metadata — worktree management files, not project code.
.claude/

# Realistic lab runtime artifacts (generated logs and bundles).
labs/realistic/reports/
/reports/
id_hetzner

# Local benchmark/profiling artifacts (never commit).
benches/reports/*.log
benches/reports/protocol-matrix-*.log
benches/reports/shared-path-local-*/
benches/reports/flamegraphs/
perf.data
perf.data.old

# Black UI local frontend/runtime artifacts.
black-ui/frontend/node_modules/
black-ui/frontend/dist/
black-ui/data/
