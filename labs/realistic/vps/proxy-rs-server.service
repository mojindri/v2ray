[Unit]
Description=proxy-rs server
After=network-online.target
Wants=network-online.target

[Service]
User=proxy-rs
Group=proxy-rs
ExecStart=/usr/local/bin/proxy-rs run -c /etc/proxy-rs/server.json
Restart=on-failure
RestartSec=3
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadOnlyPaths=/etc/proxy-rs
ReadWritePaths=/var/lib/proxy-rs

[Install]
WantedBy=multi-user.target
