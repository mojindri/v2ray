{
  "profile": "fast",
  "fast": { "strictProduction": false, "pool": "adaptive", "splice": "adaptive" },
  "log": { "level": "warn" },
  "metricsAddr": "127.0.0.1:9091",
  "inbounds": [
    {
      "tag": "vless-in",
      "protocol": "vless",
      "listen": "127.0.0.1",
      "port": 10080,
      "settings": {
        "clients": [{ "id": "00000000-0000-4000-8000-000000000001" }]
      }
    }
  ],
  "outbounds": [
    {
      "tag": "freedom",
      "protocol": "freedom",
      "settings": { "poolSize": "adaptive" }
    }
  ]
}
