# .env.example — latency lab environment variables
#
# Copy this file to .env.latency and source it, or export vars inline.
# These are NOT committed to git — they are machine/deployment-specific.

# ── VPS settings (latency-vps) ────────────────────────────────────────────────
# Client node: runs hey + blackwire client, initiates connections
VPS_CLIENT_HOST=client.example.com

# Server node: runs blackwire server + target HTTP server
# (set to the IP/hostname the CLIENT uses to reach the server)
VPS_SERVER_HOST=server.example.com

# SSH config
VPS_CLIENT_USER=root
VPS_CLIENT_PORT=22
# VPS_SSH_KEY=~/.ssh/id_hetzner    # optional — omit to use ssh-agent

# Path to this repo on the client VPS
VPS_REPO_PATH=~/Blackwire

# ── Benchmark settings ────────────────────────────────────────────────────────
BENCH_DURATION=60
BENCH_CONC=32

# ── Binary paths (override if not in PATH) ───────────────────────────────────
# BW_BIN=blackwire
# XRAY_BIN=xray
# SINGBOX_BIN=sing-box
