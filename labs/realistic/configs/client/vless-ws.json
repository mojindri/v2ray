{
  "log": { "level": "info" },
  "inbounds": [
    {
      "tag": "socks-in",
      "protocol": "socks",
      "listen": "127.0.0.1",
      "port": 1080
    }
  ],
  "outbounds": [
    {
      "tag": "vless-ws-out",
      "protocol": "vless",
      "settings": {
        "address": "${SERVER_HOST}",
        "port": 8443,
        "users": [{ "id": "${VLESS_UUID}", "flow": "" }]
      },
      "streamSettings": {
        "network": "ws",
        "security": "tls",
        "tlsSettings": {
          "serverName": "${TEST_DOMAIN}",
          "allowInsecure": false
        },
        "wsSettings": {
          "path": "/proxy",
          "headers": { "Host": "${TEST_DOMAIN}" }
        }
      }
    }
  ]
}
