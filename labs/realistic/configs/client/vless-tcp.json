{
  "log": { "level": "info" },
  "inbounds": [
    {
      "tag": "socks-in",
      "protocol": "socks",
      "listen": "127.0.0.1",
      "port": 1080
    }
  ],
  "outbounds": [
    {
      "tag": "vless-out",
      "protocol": "vless",
      "settings": {
        "address": "${SERVER_HOST}",
        "port": 10080,
        "users": [{ "id": "${VLESS_UUID}", "flow": "" }]
      }
    }
  ]
}
