# Copy to matrix.env and fill in real values before running VPS tests.
# Generate keys with: blackwire x25519

SERVER_HOST=1.2.3.4
TEST_DOMAIN=proxy.example.com

VLESS_UUID=00000000-0000-4000-8000-000000000001
VMESS_UUID=00000000-0000-4000-8000-000000000002
TROJAN_PASSWORD=correct-horse-battery-staple
SS2022_PASSWORD=correct-horse-battery-staple
HYSTERIA2_PASSWORD=correct-horse-battery-staple

# REALITY: generate with `blackwire x25519` on the server, then fill both.
REALITY_PRIVATE_KEY=REPLACE_WITH_PRIVATE_KEY
REALITY_PUBLIC_KEY=REPLACE_WITH_PUBLIC_KEY
REALITY_SHORT_ID=aabbccdd00000001
REALITY_SERVER_NAME=www.microsoft.com
REALITY_DEST=127.0.0.1:80
