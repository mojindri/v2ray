{
  "log": { "level": "info" },
  "inbounds": [
    {
      "tag": "vless-sniff-in",
      "protocol": "vless",
      "listen": "0.0.0.0",
      "port": 8452,
      "settings": {
        "clients": [{ "id": "${VLESS_UUID}", "email": "vps-user@lab", "flow": "" }]
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    }
  ],
  "outbounds": [{ "tag": "freedom", "protocol": "freedom" }]
}
