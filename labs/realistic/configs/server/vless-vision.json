{
  "log": { "level": "info" },
  "inbounds": [
    {
      "tag": "vless-vision-in",
      "protocol": "vless",
      "listen": "0.0.0.0",
      "port": 10082,
      "settings": {
        "clients": [{ "id": "${VLESS_UUID}", "email": "vps-user@lab", "flow": "xtls-rprx-vision" }]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "dest": "${REALITY_DEST}",
          "serverName": "${REALITY_SERVER_NAME}",
          "privateKey": "${REALITY_PRIVATE_KEY}",
          "shortIds": ["${REALITY_SHORT_ID}"]
        }
      }
    }
  ],
  "outbounds": [{ "tag": "freedom", "protocol": "freedom" }]
}
