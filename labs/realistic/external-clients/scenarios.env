# Xray 26+ removed legacy QUIC; sing-box proves this row.
vless-quic|server-vless-quic.json|-|vless-quic.json
# stream-one xHTTP only (Xray/sing-box). Do not set mode: packet-up until sing-box P2 parity.
vless-splithttp|server-vless-splithttp.json|vless-splithttp.json|vless-splithttp.json
# ShadowTLS v3: Xray 26+ removed security=shadowtls on outbound; server covered by e2e phase7.
vless-shadowtls|server-vless-shadowtls.json|-|-
# mKCP: external clients skipped (Xray 26 finalmask churn; sing-box has no mKCP). Server via e2e phase8.
vless-mkcp|server-vless-mkcp.json|-|-
# Sniffing: server on 8452 with destOverride; clients target same port.
vless-sniff|server-vless-sniff.json|vless-sniff.json|vless-sniff.json
