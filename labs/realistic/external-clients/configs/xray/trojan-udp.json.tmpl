{
  "log": { "loglevel": "warning" },
  "inbounds": [
    {
      "tag": "socks-in",
      "listen": "0.0.0.0",
      "port": 1080,
      "protocol": "socks",
      "settings": { "auth": "noauth", "udp": true }
    }
  ],
  "outbounds": [
    {
      "tag": "blackwire-out",
      "protocol": "trojan",
      "settings": {
        "servers": [
          { "address": "${EXTERNAL_SERVER_ADDRESS}", "port": 8445, "password": "${TROJAN_PASSWORD}" }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": { "serverName": "${EXTERNAL_TLS_SERVER_NAME}", "allowInsecure": true }
      }
    }
  ]
}
