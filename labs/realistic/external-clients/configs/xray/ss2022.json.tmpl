{
  "log": { "loglevel": "warning" },
  "inbounds": [
    { "tag": "socks-in", "listen": "0.0.0.0", "port": 1080, "protocol": "socks", "settings": { "auth": "noauth" } }
  ],
  "outbounds": [
    {
      "tag": "blackwire-out",
      "protocol": "shadowsocks",
      "settings": {
        "servers": [
          {
            "address": "${EXTERNAL_SERVER_ADDRESS}",
            "port": 8388,
            "method": "2022-blake3-aes-256-gcm",
            "password": "${SS2022_PASSWORD}"
          }
        ]
      }
    }
  ]
}

