{
  "inbounds": [
    {
      "tag": "trojan-in",
      "protocol": "trojan",
      "listen": "0.0.0.0",
      "port": 443,
      "settings": {
        "clients": [
          {
            "password": "your-strong-password-here"
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": {
          "certificateFile": "/etc/ssl/certs/server.crt",
          "keyFile": "/etc/ssl/private/server.key"
        }
      }
    }
  ],
  "outbounds": [
    {
      "tag": "freedom",
      "protocol": "freedom"
    }
  ],
  "routing": {
    "rules": [
      {
        "outboundTag": "freedom"
      }
    ]
  }
}
