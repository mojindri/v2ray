{
  "inbounds": [
    {
      "tag": "socks-in",
      "protocol": "socks",
      "listen": "127.0.0.1",
      "port": 1080
    }
  ],
  "outbounds": [
    {
      "tag": "vless-out",
      "protocol": "vless",
      "settings": {
        "address": "your-server-host-or-ip",
        "port": 443,
        "users": [
          {
            "id": "a3482e88-686a-4a58-8126-99c9df64b7bf",
            "email": "user@example.com",
            "flow": ""
          }
        ]
      },
      "streamSettings": {
        "network": "ws",
        "security": "tls",
        "tlsSettings": {
          "serverName": "your-server-host-or-ip",
          "allowInsecure": false,
          "alpn": ["h2", "http/1.1"]
        },
        "wsSettings": {
          "path": "/proxy",
          "headers": {
            "Host": "your-server-host-or-ip"
          }
        }
      }
    }
  ],
  "routing": {
    "rules": [
      {
        "outboundTag": "vless-out"
      }
    ]
  }
}
